{
  "expo": {
    "name": "TinyMD",
    "slug": "tinymd",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf9f5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "versionCode": 6,
      "package": "com.tinymd.app",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#faf9f5"
      },
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 29,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildArchs": [
              "arm64-v8a"
            ]
          }
        }
      ],
      "expo-sharing"
    ]
  }
}
